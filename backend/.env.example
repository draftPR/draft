# Backend environment variables
APP_ENV=development
DATABASE_URL=sqlite:///./kanban.db
FRONTEND_URL=http://localhost:5173

# Task backend: "sqlite" (default, no Redis needed) or "redis" (requires Redis)
# SQLite mode runs the background worker in-process — zero external dependencies.
# Redis mode uses Celery + Redis for cross-process job queues.
TASK_BACKEND=sqlite

# Redis URL (only needed when TASK_BACKEND=redis)
# REDIS_URL=redis://localhost:6379/0
